{
  "expo": {
    "name": "Stethoscan",
    "slug": "pneumoscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/favicon.jpeg",
    "scheme": "pneumoscan",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/favicon.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pneumoscan.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Stethoscan needs Bluetooth to connect to the lung sound wearable device.",
        "NSMicrophoneUsageDescription": "Stethoscan needs microphone access to record cough sounds for analysis.",
        "NSLocationWhenInUseUsageDescription": "Stethoscan uses location to detect community outbreak clusters."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon.jpeg",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.pneumoscan.app",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-av",
        {
          "microphonePermission": "Stethoscan needs microphone access to record cough sounds."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "90e0eb57-1fda-4180-b033-7f177d0b82cb"
      }
    }
  }
}
